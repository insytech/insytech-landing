---
import Layout from "@layouts/VisionLayout.astro";
import Hero from "@components/control/Hero.astro";
import Services from "@components/control/Services.astro";
import Performance from "@components/control/Performance.astro";
import Projects from "@components/control/Projects.astro";
import CTA from "@components/control/CTA.astro";
import ContactForm from "@components/sections/ContactForm.astro";
import ContactSection from "@components/sections/ContactSection.astro";
---

<Layout
    title="Sistemas de Control y Automatización de Procesos"
    description="Automatización industrial con PLC, SCADA e IoT para la manufactura inteligente. Integramos sistemas de control en todo México. Solicita tu cotización."
>
    <main class="flex flex-col overflow-hidden">
        <Hero />
        <Services />
        <Performance />
        <Projects />
        <CTA />

        <ContactSection />
    </main>
</Layout>
